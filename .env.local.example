# ============================================================
# FitCoach AI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in the values
# Never commit .env.local to version control

# ============================================================
# APP
# ============================================================
# Base URL of your application (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# SUPABASE
# ============================================================
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to client
# Found in: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# OPENAI
# ============================================================
# Found in: platform.openai.com > API Keys
OPENAI_API_KEY=sk-...

# Model to use for AI generation (gpt-4o recommended)
OPENAI_MODEL=gpt-4o

# ============================================================
# STRIPE
# ============================================================
# Found in: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret — obtained when creating webhook endpoint
# Local: use `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# Production: Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in Stripe Dashboard)
# Pro plan: $29/month
STRIPE_PRO_PRICE_ID=price_...
# Premium plan: $79/month
STRIPE_PREMIUM_PRICE_ID=price_...

# ============================================================
# UPSTASH REDIS (Rate Limiting)
# ============================================================
# Found in: console.upstash.com > Database > REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ============================================================
# SENTRY (Error Tracking)
# ============================================================
# Found in: sentry.io > Project Settings > SDK Setup
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
SENTRY_ORG=your-org
SENTRY_PROJECT=fitcoach-ai
SENTRY_AUTH_TOKEN=sntrys_...

# ============================================================
# POSTHOG (Analytics)
# ============================================================
# Found in: app.posthog.com > Project Settings > API Keys
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
